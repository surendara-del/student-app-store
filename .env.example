# Production Environment Configuration for Render
# Copy this to your Render environment variables (not to .env file)

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-secure-random-secret-key-here

# Database (SQLite is fine for Render)
DATABASE_URL=sqlite:///app_store.db

# Google OAuth Configuration
# Get these values from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://your-app-name.onrender.com/auth/google/callback

# Upload settings (configured in code)
MAX_CONTENT_LENGTH=104857600  # 100MB in bytes
UPLOAD_FOLDER=uploads
